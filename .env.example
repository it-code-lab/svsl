# Flask
SECRET_KEY=change-this-secret
DATABASE_URL=sqlite:///scheduler.db
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=2048
APP_TIMEZONE=America/Montreal

# Scheduler
ENABLE_SCHEDULER=true
SCHEDULER_INTERVAL_SECONDS=60
ADMIN_RUN_KEY=change-me

# Cache selectable destinations locally to reduce API calls
DESTINATION_CACHE_TTL_MINUTES=360

# YouTube OAuth files
YOUTUBE_CLIENT_SECRET_FILE=instance/youtube_client_secret.json
YOUTUBE_TOKEN_FILE=instance/youtube_token.json
YOUTUBE_TOKEN_DIR=instance/youtube_tokens

# Facebook / Meta Graph API
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:5001/oauth/facebook/callback
FACEBOOK_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts

# Optional backward-compatible fallback for one fixed Page
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# TikTok Content Posting API
TIKTOK_ACCESS_TOKEN=

# Pinterest OAuth
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=http://127.0.0.1:5001/oauth/pinterest/callback
PINTEREST_SCOPES=pins:read,pins:write,boards:read
PINTEREST_CONTINUOUS_REFRESH=true

# Optional backward-compatible fallback for one fixed board/manual token
PINTEREST_BOARD_ID=
PINTEREST_ACCESS_TOKEN=
